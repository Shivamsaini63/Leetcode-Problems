class Solution {
    public int removeElement(int[] nums, int val) {
        int n=nums.length;
        int a=0;
        for(int i=0; i<n; i++){
            if(nums[i]!=val){
                int temp=nums[a];
                nums[a]=nums[i];
                nums[i]=temp;

                a++;
            }
        }
        return a;
    }
}

class Solution {
    public int[] sortArrayByParity(int[] nums) {
        int n=nums.length;
        int lo=0;
        int hi=n-1;
        while(lo<hi){
            if(nums[lo]%2>nums[hi]%2){
                int temp=nums[lo];
                nums[lo]=nums[hi];
                nums[hi]=temp;
            }
            if(nums[lo]%2==0) lo++;
            if(nums[hi]%2==1) hi--;
        }
        return nums;
    }
}
